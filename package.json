{
  "name": "platphorm-frwf",
  "private": true,
  "version": "1.1.0",
  "packageManager": "pnpm@11.13.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:regression": "playwright test",
    "test:playability": "playwright test e2e/playability-regressions.spec.ts",
    "test:soak": "playwright test e2e/rematch-soak.spec.ts",
    "test:soak:5m": "RUN_LONG_SOAK=true playwright test e2e/five-minute-soak.spec.ts",
    "test:ai-soak": "vitest run src/tests/aiSoak.test.ts --reporter=verbose",
    "test:watch": "vitest",
    "lint": "eslint . --max-warnings 0",
    "preview": "vite preview",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "verify:regression": "pnpm verify && pnpm test:regression"
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "0.19.2",
    "@frwf/game-protocol": "workspace:*",
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.6.1",
    "@react-three/rapier": "2.2.0",
    "colyseus.js": "^0.15.28",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "three": "0.185.1",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.185.1",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "10.7.0",
    "jsdom": "^29.1.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
