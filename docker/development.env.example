# RINGFALL game server environment variables.
# Copy to .env in the server/ directory and fill in production values.
# Never commit a .env file with real secrets.

# ── Server ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=2567
HOSTNAME=0.0.0.0

# ── Redis (required for multi-region or multi-instance deployments) ────────────
# Leave unset for single-instance local development (uses in-memory presence).
REDIS_URL=redis://localhost:6379

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins, or * for all (development only).
CORS_ORIGIN=http://localhost:5173

# ── Colyseus monitor (development only, never expose publicly in production) ───
MONITOR_ENABLED=true

# ── Observability ──────────────────────────────────────────────────────────────
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# LOG_LEVEL=info
